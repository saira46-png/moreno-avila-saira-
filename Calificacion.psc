Algoritmo Calificacion
	definir cal1 como entero
	definir cal2 Como Entero
	definir cal3 Como Entero
	
	escribir "ingresar tu primera calificacion"
	leer cal1
	escribir "ingresar segunda calificacion"
	leer cal2
	escribir "ingresar tercera calificacion"
	leer cal3
	
	prom = (cal1+cal2+cal3)/3
	
	escribir "tu promedio es:", prom
	leer prom
FinAlgoritmo
